{
  "Poc": {
    "EndpointPrefix": "tenant",
    "PartitionsPerTenant": 3,
    "SqlTransport": {
      "ConnectionString": "Server=localhost,1433;User Id=sa;Password=Your_password123;TrustServerCertificate=True;Encrypt=False;Max Pool Size=200;",
      "MainSchema": "dbo",
      "PartitionSchemaPrefix": "p",
      "DatabasePrefix": "NsbPoc_",
      "ErrorQueue": "error@dbo@ServiceControl",
      "AuditQueue": "audit@dbo@ServiceControlAudit",
      "HeartbeatQueue": "Particular.ServiceControl@dbo@ServiceControl",
      "TransactionMode": "SendsAtomicWithReceive"
    },
    "Tenants": [
      {
        "TenantId": "tenant-a",
        "MainEndpointConcurrency": 2
      },
      {
        "TenantId": "tenant-b",
        "MainEndpointConcurrency": 2
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "NServiceBus": "Debug",
      "NServiceBus.Transport.Sql": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Polly": "Warning"
    }
  },
  "HostOptions": {
    "ServicesStartConcurrently": true
  },
  "TrafficGenerator": {
    "Enabled": true,
    "StartupDelaySeconds": 5,
    "MinDelayMs": 900,
    "MaxDelayMs": 1600
  },
  "AllowedHosts": "*"
}
